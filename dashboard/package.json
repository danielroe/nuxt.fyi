{
  "name": "nuxt-fyi-dashboard",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --dotenv ../.env",
    "dev:ui-only": "NUXT_UI_ONLY=1 NODE_OPTIONS=\"${NODE_OPTIONS:-} --use-env-proxy\" nuxt dev --dotenv ../.env",
    "dev:fixtures": "NUXT_FIXTURES=1 nuxt dev --dotenv ../.env",
    "postinstall": "nuxt prepare",
    "preview": "node .output/server/index.mjs",
    "test:types": "nuxt typecheck"
  },
  "dependencies": {
    "@nuxt/image": "^2.0.0",
    "defu": "^6.1.7",
    "h3": "2.0.1-rc.22",
    "nitro": "3.0.260522-beta",
    "nuxt": "npm:nuxt-nightly@5.0.0-29709953.369a6c64",
    "vue": "^3.5.0",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "fetchdts": "0.1.7",
    "typescript": "6.0.3",
    "vue-tsc": "3.3.5"
  }
}
