{
  "name": "@nuxt-fyi/daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "start": "node --env-file-if-exists=../../.env src/index.ts",
    "dev": "node --watch --env-file-if-exists=../../.env src/index.ts",
    "probe": "node --env-file-if-exists=../../.env src/cli/probe.ts",
    "rescan": "node --env-file-if-exists=../../.env src/cli/rescan.ts",
    "stats": "node --env-file-if-exists=../../.env src/cli/stats.ts",
    "status": "node --env-file-if-exists=../../.env src/cli/status.ts",
    "test": "node --test 'src/**/*.test.ts'",
    "test:types": "tsc --noEmit",
    "ingest-tranco": "node scripts/ingest-tranco.mjs",
    "ingest-nuxt-versions": "node scripts/ingest-nuxt-versions.mjs",
    "backfill-images": "node --env-file-if-exists=../../.env src/cli/backfill-images.ts",
    "backfill-nsfw": "node --env-file-if-exists=../../.env scripts/backfill-nsfw.mjs"
  },
  "dependencies": {
    "@atproto/api": "^0.20.6",
    "@imagekit/nodejs": "^7.6.2",
    "consola": "^3.4.0",
    "tldts": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "typescript": "6.0.3"
  }
}
