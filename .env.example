# Discord webhook to post detections into
DISCORD_WEBHOOK_URL=

# Bluesky posting (optional). Generate an app password under Settings -> Privacy & security -> App passwords.
BLUESKY_SERVICE=https://bsky.social
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
# Minimum gap between Bluesky posts in ms (default 15 minutes).
BLUESKY_MIN_INTERVAL_MS=900000

# Jetstream endpoint (pick a regional instance)
JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe

# Concurrency for the scanner workers
SCAN_CONCURRENCY=2

# How long before we'll rescan a domain (ms). Default 30 days.
RESCAN_AFTER_MS=2592000000

# Where to store sqlite + screenshots
NUXT_DATA_DIR=./data
NUXT_SCREENSHOT_DIR=./screenshots

# Maximum bytes the screenshot directory is allowed to use. Oldest files are evicted when
# this is exceeded. Default 500MB.
SCREENSHOT_CAP_BYTES=524288000

# Set to 1 to log every post seen
VERBOSE=0

# ImageKit (https://imagekit.io). Screenshots and og:images get uploaded here so the
# dashboard can render them via @nuxt/image. Leave the keys empty to disable uploads;
# the daemon will keep writing local screenshots and the dashboard falls back to those.
IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
# Base folder for uploads. Screenshots end up at <root>/screenshots/<domain>.jpg and
# og:images at <root>/og-images/<domain>.<ext>.
IMAGEKIT_ROOT_FOLDER=/nuxt-fyi

# Screenshot scanner service. The daemon delegates screenshot capture + ImageKit upload
# to a separate process (run `pnpm dev:scanner` in another terminal locally; in prod this
# is a separate Fly app reachable via private networking). Leave empty to disable remote
# capture: the dashboard then only renders og:images for new scans.
SCANNER_URL=http://localhost:3001
SCANNER_TOKEN=
